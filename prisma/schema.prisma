// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core authentication and multi-tenant models
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedOrganizations Organization[]
  memberships        OrgMembership[]
  auditLogs          AuditLog[]

  @@index([email])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  plan      String   @default("free") // free, pro, enterprise
  createdAt DateTime @default(now())

  // Relations
  owner                User                   @relation(fields: [ownerId], references: [id])
  memberships          OrgMembership[]
  campaigns            Campaign[]
  destinationCredentials DestinationCredential[]
  publishRuns          PublishRun[]
  submissions          DestinationSubmission[]
  auditLogs            AuditLog[]

  @@index([slug])
  @@index([ownerId])
}

model OrgMembership {
  userId String
  orgId  String
  role   String @default("member") // owner, admin, member

  // Relations
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId])
  @@index([orgId])
}

// Campaign and content models
model Campaign {
  id                String   @id @default(cuid())
  orgId             String
  sourceUrl         String?
  sourceType        String?  // article, blog_post, etc.
  canonicalSiteUrl  String?
  utmPolicy         String?
  status            CampaignStatus @default(draft)
  siteBrief         Json?    // SiteBrief object
  claimsMap         Json?    // ClaimsMap object
  pillars           Json?    // CampaignSpec pillars
  primaryCtas       Json?    // CTA objects
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contentAssets     ContentAsset[]
  publishRuns       PublishRun[]
  submissions       DestinationSubmission[]
  trackingLinks     TrackingLink[]

  @@index([orgId])
  @@index([status])
  @@index([createdAt])
}

model ContentAsset {
  id                String   @id @default(cuid())
  campaignId        String
  assetType         AssetType
  title             String
  bodyMarkdown      String
  excerpt           String?
  tags              String[]
  heroImage         String?
  canonicalUrl      String?
  claims            Json?    // Array of claims
  disclosures       String?
  status            AssetStatus @default(draft)
  uniquenessScore   Float?
  version           Int      @default(1)
  originalBodyMd    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  campaign          Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submissions       DestinationSubmission[]
  trackingLinks     TrackingLink[]

  @@index([campaignId])
  @@index([assetType])
  @@index([status])
  @@index([createdAt])
}

// Destination configuration and credentials
model Destination {
  id                String   @id @default(cuid())
  key               String   @unique
  name              String
  group             String   // api, feed, assist
  requiredFields    Json?    // Array of field definitions
  authType          String?  // oauth, apikey, basic, none
  limits            Json?    // Rate limits, size limits, etc.
  supportsCanonical Boolean  @default(false)
  enabled           Boolean  @default(true)
  config            Json?    // Additional configuration

  // Relations
  credentials       DestinationCredential[]
  submissions       DestinationSubmission[]

  @@index([key])
  @@index([group])
}

model DestinationCredential {
  id              String   @id @default(cuid())
  orgId           String
  destinationId   String
  credentials     String   // Encrypted JSON
  tokenExpiry     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  destination     Destination  @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([orgId, destinationId])
  @@index([orgId])
  @@index([destinationId])
}

// Publishing and tracking
model DestinationSubmission {
  id                String   @id @default(cuid())
  assetId           String
  destinationId     String
  campaignId        String
  orgId             String
  prefillJson       Json?
  validationReport  Json?
  status            SubmissionStatus @default(queued)
  externalId        String?
  publishedUrl      String?
  errorLog          String?
  idempotencyKey    String   @unique
  attempts          Int      @default(0)
  lastAttemptAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  asset             ContentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  destination       Destination  @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  campaign          Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  trackingLinks     TrackingLink[]

  @@unique([assetId, destinationId])
  @@index([campaignId])
  @@index([orgId])
  @@index([destinationId])
  @@index([status])
  @@index([createdAt])
}

model PublishRun {
  id        String   @id @default(cuid())
  campaignId String
  orgId     String
  mode      PublishMode @default(dry_run)
  status    PublishStatus @default(pending)
  startedAt DateTime?
  completedAt DateTime?
  summary   Json?

  // Relations
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([orgId])
  @@index([status])
  @@index([createdAt])
  createdAt DateTime @default(now())
}

model TrackingLink {
  id              String   @id @default(cuid())
  submissionId    String?
  campaignId      String
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  redirectUrl     String
  originalUrl     String
  clicks          Int      @default(0)
  createdAt       DateTime @default(now())

  // Relations
  submission      DestinationSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([submissionId])
  @@index([createdAt])
}

// Audit and compliance
model AuditLog {
  id         String   @id @default(cuid())
  orgId      String
  userId     String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  // Relations
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

// Enums
enum CampaignStatus {
  draft
  generating
  ready
  publishing
  completed
  failed
}

enum AssetType {
  article
  press_release
  newsletter
  social_snippet
  video_script
  podcast_script
}

enum AssetStatus {
  draft
  approved
  published
  failed
}

enum SubmissionStatus {
  queued
  sending
  sent
  failed
  manual_needed
  skipped
}

enum PublishMode {
  dry_run
  live
}

enum PublishStatus {
  pending
  running
  completed
  failed
}
