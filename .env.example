# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database
DATABASE_URL=your_database_connection_string

# Feature Flags
MOCK_DESTINATIONS=false

# Search Engine Submission
INDEXNOW_KEY=your_indexnow_key

# Social Media & Blogging Platforms (Optional)
GHOST_ADMIN_KEY=your_ghost_admin_key
GHOST_API_URL=your_ghost_blog_url

BLOGGER_BLOG_ID=your_blogger_blog_id
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

HASHNODE_TOKEN=your_hashnode_api_token
HASHNODE_USERNAME=your_hashnode_username

LINKEDIN_ACCESS_TOKEN=your_linkedin_oauth_token

TUMBLR_CONSUMER_KEY=your_tumblr_consumer_key
TUMBLR_CONSUMER_SECRET=your_tumblr_consumer_secret
TUMBLR_ACCESS_TOKEN=your_tumblr_access_token
TUMBLR_ACCESS_TOKEN_SECRET=your_tumblr_access_token_secret
TUMBLR_BLOG_NAME=your_tumblr_blog_name

# Search Console
GOOGLE_SEARCH_CONSOLE_PROPERTY=your_gsc_property_url

# Bing Webmaster
BING_WEBMASTER_API_KEY=your_bing_webmaster_key
BING_WEBMASTER_SITE_URL=your_site_url

# PR Distribution Services (Optional)
OPENPR_API_KEY=your_openpr_api_key
PRESSRELEASE1888_API_KEY=your_pressrelease1888_api_key
PRESSRELEASE1888_ACCOUNT_ID=your_pressrelease1888_account_id

# Cache & Queue (Redis)
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
VERCEL_ENV=development
